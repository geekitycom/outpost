{
  "name": "outpost",
  "version": "1.1.0",
  "description": "A folder-based HTTP server that serves static and rendered (HTML/OPML/Markdown) pages per domain. Inspired by Dave Winer's PagePark.",
  "type": "module",
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "eta": "^4.6.0",
    "fast-xml-parser": "^5.9.3",
    "hono": "^4.6.14",
    "marked": "^18.0.6",
    "mime-types": "^3.0.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.10.2",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.63.0",
    "vitest": "^2.1.8"
  },
  "license": "MIT"
}
