{
  "name": "outpost",
  "version": "1.0.0",
  "description": "A folder-based HTTP server that serves static and rendered (HTML/OPML/Markdown) pages per domain. Inspired by Dave Winer's PagePark.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "fast-xml-parser": "^5.9.3",
    "hono": "^4.6.14",
    "marked": "^18.0.6",
    "mime-types": "^3.0.2"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "license": "MIT"
}
